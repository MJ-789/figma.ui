# =====================================================
# 最小化配置模板 —— 只改这 3 项就能跑起来
# =====================================================
# 切换到新网站/新设计稿时，仅修改下方 3 个配置即可，
# 其余参数全部走代码默认值，无需手动覆盖。

# 1) Figma 访问令牌（必填）
#    获取: https://www.figma.com/settings/personal-access-tokens
FIGMA_ACCESS_TOKEN=your_figma_token_here

# 2) Figma 设计稿 URL（必填）
#    直接粘贴浏览器地址栏里的完整链接，FILE_KEY 和 TARGET_NODE_ID
#    会从中自动解析，不用再拆成多个字段填。
FIGMA_DESIGN_URL=https://www.figma.com/design/<fileKey>/<Slug>?node-id=15480-72

# 3) 被测网站根 URL（必填）
BASE_URL=https://your-site.com


# =====================================================
# 以下全部可选 —— 默认值能覆盖 95% 场景，没需要不用填
# =====================================================

# 浏览器
# DEFAULT_BROWSER=chromium
# HEADLESS=true

# 整页截图视觉对比阈值 (0-100，越高越严)
# SIMILARITY_THRESHOLD=95

# ── 元素属性对比容差 ─────────────────────────────
# COMPARE_COLOR_TOLERANCE=5         # 颜色通道差
# COMPARE_SIZE_TOLERANCE=4          # 尺寸/位置 px
# COMPARE_RADIUS_TOLERANCE=2        # 圆角 px
# COMPARE_ELEMENT_THRESHOLD=0.70    # 元素通过率阈值
# COMPARE_MAX_DEPTH=4               # Figma 节点提取深度
# COMPARE_MIN_MATCH_COUNT=3         # 最小样本数

# ── 自动代理 (run_agent.py) ───────────────────────
# DISCOVERY_SEED_PATHS=/
# DISCOVERY_MAX_DEPTH=2
# DISCOVERY_MAX_PAGES=20
# PAGE_MATCH_MIN_CONFIDENCE=0.40

# ── 视口 / 干扰元素 ───────────────────────────────
# AGENT_VIEWPORT_WIDTH=1440
# AGENT_VIEWPORT_HEIGHT=900
# AGENT_HIDE_SELECTORS=.advertisement,.cookie-banner,[class*='timestamp'],[id*='chat']

# ── 兼容: 旧版分字段配置 (和 FIGMA_DESIGN_URL 二选一) ──
# FIGMA_FILE_KEY=fYPLGfJU35LLvqgBvUQ1bG
# FIGMA_TARGET_NODE_ID=15480:72
