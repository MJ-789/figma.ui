FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
BASE_URL=https://example.com

# 基础运行配置
DEFAULT_BROWSER=chromium
HEADLESS=true
SIMILARITY_THRESHOLD=95

# 旧版页面截图/元素对比配置（兼容现有用例）
HOMEPAGE_FIGMA_NODE=15661-163
HOMEPAGE_URL=/
HOMEPAGE_WAIT_FOR=
HOMEPAGE_WIDTH=1920
HOMEPAGE_HEIGHT=900
PAGE_MAP=

# 旧版多页面爬取配置
CRAWL_ENABLED=true
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=20
CRAWL_MAX_CLICKS_PER_PAGE=8
CRAWL_SEED_PATHS=/
CRAWL_CLICK_SELECTORS=a[href],button,[role='link'],[role='button']
CRAWL_EXCLUDE_KEYWORDS=logout,signout,delete,remove

# 元素级对比配置
COMPARE_COLOR_TOLERANCE=5
COMPARE_SIZE_TOLERANCE=4
COMPARE_FONT_SIZE_TOLERANCE=1
COMPARE_RADIUS_TOLERANCE=2
COMPARE_ELEMENT_THRESHOLD=0.70
COMPARE_MAX_DEPTH=4
COMPARE_MIN_MATCH_COUNT=3

# vNext: 自动测试代理模式
AGENT_MODE=false
DISCOVERY_ENABLED=true
DISCOVERY_MAX_DEPTH=2
DISCOVERY_MAX_PAGES=20
DISCOVERY_SEED_PATHS=/,/pricing,/about
DISCOVERY_EXCLUDE_KEYWORDS=logout,signout,delete,remove

PAGE_MATCH_ENABLED=true
PAGE_MATCH_TOP_K=3
PAGE_MATCH_MIN_CONFIDENCE=0.70

AGENT_VIEWPORT_WIDTH=1440
AGENT_VIEWPORT_HEIGHT=900
AGENT_HIDE_SELECTORS=.advertisement,.cookie-banner,[class*='timestamp'],[id*='chat']

# LLM 配置（后续页面配对 / 元素配对模块使用）
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=60
LLM_MAX_CANDIDATES=3
